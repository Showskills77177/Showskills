{
  "name": "showskills",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "dev:e2e": "concurrently -k \"node server.js\" \"vite --port 5173 --strictPort\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:setup": "node db/setup.js",
    "db:schema": "node db/schema.js",
    "seed:kickup": "node scripts/seed-kickup-video.mjs",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:admin": "playwright test tests/e2e/admin.spec.js",
    "test:payment": "playwright test tests/e2e/payment-mocked.spec.js",
    "test:ui": "playwright test --ui",
    "test:install": "playwright install chromium"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.2",
    "bcryptjs": "^2.4.3",
    "jose": "^5.10.0",
    "pg": "^8.14.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1"
  }
}
