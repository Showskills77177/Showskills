# Optional overrides for Playwright (see tests/README.md).
# Copy to .env.e2e if you want non-default admin credentials or E2E secret.

# E2E_SECRET must match server when E2E_MODE=1 (playwright.config sets defaults).
# E2E_SECRET=your-long-random-secret

# E2E_ADMIN_USER=custom-admin
# E2E_ADMIN_PASSWORD=custom-password
# ADMIN_JWT_SECRET=must-be-at-least-32-characters-long!!
