# Stripe test mode — use ONE of these approaches:

# Option A: Stripe Payment Link (simplest for static sites). Create in Dashboard → Payment links (test mode).
VITE_STRIPE_PAYMENT_LINK=

# Option B: Checkout Session from your backend (returns { sessionId } JSON).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_CHECKOUT_API_URL=https://your-api.example.com/create-checkout-session
