# Stripe test mode — use ONE of these approaches:

# Option A: Stripe Payment Link (simplest; no server). Dashboard → Payment links (test mode).
VITE_STRIPE_PAYMENT_LINK=

# Option B: Checkout Session — this repo includes /api/create-checkout-session on Vercel.
# Add these in Vercel → Settings → Environment Variables (redeploy after changes).
# STRIPE_SECRET_KEY is server-only (never VITE_).
STRIPE_SECRET_KEY=sk_test_...
# Ticket totals are fixed bundles in shared/ticketBundles.mjs (not env). STRIPE_CHECKOUT_AMOUNT_PENCE is ignored by create-checkout-session.
# STRIPE_CHECKOUT_AMOUNT_PENCE=100
# STRIPE_CURRENCY=gbp

VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional: override the default API path (production default: /api/create-checkout-session)
# VITE_STRIPE_CHECKOUT_API_URL=https://your-api.example.com/create-checkout-session

# PayPal (optional second processor) — bundle totals match shared/ticketBundles.mjs (same as Stripe).
# Create a REST app in PayPal Developer (Sandbox or Live). Server secrets never use VITE_.
VITE_PAYPAL_CLIENT_ID=
# Must match purchase currency (PayPal uses uppercase, e.g. GBP)
# VITE_PAYPAL_CURRENCY=GBP
# Optional: override API paths (defaults: {BASE_URL}/api/create-paypal-order and capture-paypal-order)
# VITE_PAYPAL_CREATE_ORDER_URL=
# VITE_PAYPAL_CAPTURE_ORDER_URL=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox (default) or live
# PAYPAL_MODE=sandbox
# Optional explicit API host (otherwise derived from PAYPAL_MODE)
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# PAYPAL_UNIT_AMOUNT_PENCE is unused; order amount comes from the selected bundle server-side.
# PAYPAL_UNIT_AMOUNT_PENCE=100
# PAYPAL_CURRENCY=GBP

# Local dev: `npm run dev:all` (Vite + Express `server.js` on :3000), or `npm run dev:api` + `npm run dev`.
# Test API: curl -X POST http://localhost:3000/api/login -H 'Content-Type: application/json' -d '{"username":"admin","password":"admin"}'
# If the API is on another host/port, set e.g. VITE_PROXY_API_TARGET=http://127.0.0.1:3001
# Do not set VITE_API_BASE for normal local dev — the app uses same-origin /api and Vite proxies to :3000.
# Setting VITE_API_BASE=http://127.0.0.1:3000 while opening the site on localhost causes CORS / “Network error”.
# Override proxy target only in vite.config.js (VITE_PROXY_API_TARGET). For rare direct API calls: VITE_DEV_DIRECT_API=true
# VITE_STRIPE_CHECKOUT_API_URL=http://127.0.0.1:3000/api/create-checkout-session
# PayPal APIs work the same way under `vercel dev` when PAYPAL_* secrets are set.

# Database — use ONE of:
# A) Local SQLite (default for `npm run dev:api`): npm run db:setup && npm run db:schema
SQLITE_PATH=db/db.sqlite
# B) Hosted Postgres (e.g. Vercel): set DATABASE_URL and leave SQLITE_PATH unset
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Admin panel (/admin) — never commit real values
ADMIN_USER=admin
# Plain password (dev) or bcrypt hash (recommended prod): ADMIN_PASSWORD_HASH=$2a$...
# Quote if the password contains # or leading special characters, e.g. ADMIN_PASSWORD=":admin"
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
# Min 32 characters; used to sign HttpOnly session cookie
ADMIN_JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Kick-up video uploads: Vercel has no persistent disk. Run the multipart upload API on a small VPS / Fly.io / Render
# (same repo `server.js` or a minimal fork) and point the frontend at that host, or switch to S3-compatible storage
# (Cloudflare R2, Backblaze B2, Wasabi) and store public or signed https URLs in `video_ref` instead of `local:…`.
# Local dev writes to ./uploads/kickups; admin delete removes the DB row and that file when `video_ref` is local.
